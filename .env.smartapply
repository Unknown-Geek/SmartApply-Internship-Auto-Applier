# =============================================================================
# SmartApply — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.smartapply .env
# =============================================================================

# ---- Cerebras API Key (REQUIRED) ----
# Get yours at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# ---- Model ----
# Options: gpt-oss-120b, llama-4-scout-17b-16e, etc.
CEREBRAS_MODEL=gpt-oss-120b

# ---- FastAPI Server ----
HOST=0.0.0.0
PORT=8000
APP_ENV=development

# ---- SmartApply Agent Settings ----
HEADLESS=true
BROWSER_TIMEOUT=60000
MAX_AGENT_STEPS=25
AGENT_TIMEOUT_SECONDS=600

# ---- SQLite Database (stored in app/db/) ----
SQLITE_DB_PATH=./app/db/smartapply.db

# ---- Telegram Bot (optional) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
