        },
        {
            "parameters": {
                "operation": "update",
                "documentId": {
                    "__rl": true,
                    "mode": "list",
                    "value": "YOUR_SPREADSHEET_ID"
                },
                "sheetName": {
                    "__rl": true,
                    "mode": "list",
                    "value": "Applications"
                },
                "columns": {
                    "mappingMode": "defineBelow",
                    "value": {
                        "status": "ERROR",
                        "applied_at": "={{ new Date().toISOString() }}",
                        "result_message": "={{ $json.error || 'Analysis failed' }}",
                        "screenshot_url": "",
                        "actions_executed": "0"
                    },
                    "matchingColumns": [
                        "row_id"
                    ]
                },
                "options": {}
            },
            "id": "log-error-analyze",
            "name": "Log Error (Analyze)",
            "type": "n8n-nodes-base.googleSheets",
            "typeVersion": 4.5,
            "position": [
                1120,
                520
            ],
            "credentials": {
                "googleSheetsOAuth2Api": {
                    "id": "YOUR_CREDENTIALS_ID",
                    "name": "Google Sheets Account"
