# =============================================================================
# SmartApply Web Agent - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.template .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Cerebras API Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Get your API key from: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Model to use (default: gpt-oss-120b)
CEREBRAS_MODEL=gpt-oss-120b

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Environment: development, staging, production
APP_ENV=development

# Server configuration
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# Browser Agent Settings
# -----------------------------------------------------------------------------
# Set to "true" to run browser in headless mode (required for servers)
HEADLESS=true

# Browser timeout in milliseconds (default: 60000)
BROWSER_TIMEOUT=60000

# Maximum agent reasoning steps per task
MAX_AGENT_STEPS=25

# Agent timeout in seconds
AGENT_TIMEOUT_SECONDS=600

# -----------------------------------------------------------------------------
# Telegram Bot (optional — enables human-in-the-loop)
# -----------------------------------------------------------------------------
# Create a bot via @BotFather on Telegram, then get your chat ID
# by messaging @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
