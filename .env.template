# =============================================================================
# SmartApply — Environment Variables Template
# =============================================================================
# Copy this to .env and fill in your values:
#   cp .env.template .env
# =============================================================================

# -----------------------------------------------------------------------------
# Cerebras API (Required)
# -----------------------------------------------------------------------------
# Get your API key at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_TEMPERATURE=0.3

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=development
PORT=8000
HEADLESS=true

# -----------------------------------------------------------------------------
# Agent Settings
# -----------------------------------------------------------------------------
MAX_AGENT_STEPS=25
AGENT_TIMEOUT_SECONDS=600

# -----------------------------------------------------------------------------
# Telegram Bot (Optional — enables human-in-the-loop)
# -----------------------------------------------------------------------------
# 1. Create a bot via @BotFather on Telegram → copy the token
# 2. Message @userinfobot on Telegram → copy your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Google Sheets Profile Sync (Optional)
# -----------------------------------------------------------------------------
# Place your service_account.json in the project root
# Run: python3 sync_profile.py
# Sheet ID is configured in sync_profile.py

# -----------------------------------------------------------------------------
# n8n Queue Integration (Optional)
# -----------------------------------------------------------------------------
# Webhook URL to queue forwarded Telegram links (e.g. from queue_application.json)
SMARTAPPLY_QUEUE_WEBHOOK=

# -----------------------------------------------------------------------------
# SQLite Database (auto-created)
# -----------------------------------------------------------------------------
SQLITE_DB_PATH=./app/db/smartapply.db
