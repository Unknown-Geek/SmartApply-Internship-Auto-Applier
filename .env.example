# Smart Apply — Environment Configuration
# Copy this to .env and fill in your values

# ─── Applicant Identity ───────────────────────────────────────────────────────
IDENTITY_CSV_PATH=/app/data/identity/identity.csv
RESUME_PDF_PATH=/app/data/identity/resume.pdf

# ─── Ollama / LLM ─────────────────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
LLM_MODEL=qwen3:8b
LLM_CONTEXT_SIZE=32768
LLM_TEMPERATURE=0.1

# ─── FastAPI ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-please

# ─── API Key Auth ─────────────────────────────────────────────────────────────
# Comma-separated list of API keys. Leave empty to disable auth.
# Pass keys via: ?api_key=KEY, X-API-Key header, or Authorization: Bearer KEY
API_KEYS=

# ─── PinchTab ─────────────────────────────────────────────────────────────────
PINCHTAB_DAEMON_URL=http://localhost:9867
CHROME_NO_SANDBOX=true

# ─── context-mode ─────────────────────────────────────────────────────────────
CONTEXT_MODE_URL=http://context-mode:3100

# ─── Agent Behavior ───────────────────────────────────────────────────────────
AGENT_MAX_STEPS=20
AGENT_TIMEOUT_SECONDS=300
MAX_CONCURRENT_AGENTS=1

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ─── n8n Integration (optional) ───────────────────────────────────────────────
# Webhook URL for the 'SmartApply - Application Logger' n8n workflow.
# When set, the backend will POST results here after every agent run.
# Leave blank to disable.
N8N_LOG_WEBHOOK_URL=https://your-n8n-instance/webhook/smartapply-log

# Webhook URL for the 'SmartApply - Telegram Q&A Handler' n8n workflow.
# When set, the backend will POST questions here mid-run so you can answer
# via Telegram. Leave blank to disable (agent will skip unanswerable fields).
N8N_QUESTION_WEBHOOK_URL=https://n8n.shravanpandala.me/webhook/smartapply-question

# How long (seconds) the agent waits for your Telegram reply before skipping.
# Default: 300 (5 minutes)
HUMAN_INPUT_TIMEOUT_SECONDS=300

# n8n env vars — set these inside your n8n instance, not in this file:
#   SMARTAPPLY_API_URL  = http://172.18.0.1:8000   (backend URL from n8n's network)
#   TELEGRAM_CHAT_ID    = your Telegram chat/user ID (get via @userinfobot)

# Host IP used by n8n to reach the backend (usually the Docker bridge gateway).
# The Profile Sync workflow POSTs to http://<N8N_BACKEND_HOST>:8000/profile/ingest/direct
# Default in n8n workflows: 172.18.0.1 (Docker bridge on Linux)
N8N_BACKEND_HOST=172.18.0.1
