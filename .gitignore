# =============================================================================
# SmartApply — Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets (NEVER commit these!)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.smartapply
*.key
*.pem
service_account.json

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.db
*.db-journal
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -----------------------------------------------------------------------------
# Virtual Environment
# -----------------------------------------------------------------------------
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# -----------------------------------------------------------------------------
# Logs & Temp Files
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/

# -----------------------------------------------------------------------------
# Browser / Playwright
# -----------------------------------------------------------------------------
screenshots/
recordings/
